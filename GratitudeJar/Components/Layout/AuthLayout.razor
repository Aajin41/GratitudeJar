@inherits LayoutComponentBase

<div class="auth-shell">
    <div class="auth-logo-block">
        <img src="/images/applogo.png" class="auth-logo-img" alt="Citadel" />
        <p class="auth-welcome">Welcome to</p>
        <h1 class="auth-title">Citadel</h1>
    </div>

    <div class="auth-divider">
        <div class="auth-divider-line"></div>
        <span class="auth-divider-heart">&#9825;</span>
        <div class="auth-divider-line"></div>
    </div>

    <div class="auth-card">
        @Body
    </div>
</div>
