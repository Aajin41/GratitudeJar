@inject NavigationManager Nav

<nav class="bottom-nav">
    <a href="/" class="nav-tab @(IsActive("/", exact: true) ? "nav-tab--active" : "")">
        <img src="/images/taskbar_home.png" class="nav-icon-img" alt="Home" />
        <span class="nav-label">Home</span>
    </a>
    <a href="/jar" class="nav-tab @(IsActive("/jar") ? "nav-tab--active" : "")">
        <img src="/images/taskBar_jar.png" class="nav-icon-img" alt="Jar" />
        <span class="nav-label">Jar</span>
    </a>
    <a href="/entries" class="nav-tab @(IsActive("/entries") ? "nav-tab--active" : "")">
        <img src="/images/taskBar_file.png" class="nav-icon-img" alt="Entries" />
        <span class="nav-label">Entries</span>
    </a>
    <a href="/user" class="nav-tab @(IsActive("/user") ? "nav-tab--active" : "")">
        <img src="/images/taskBar_profile.png" class="nav-icon-img" alt="Profile" />
        <span class="nav-label">Profile</span>
    </a>
</nav>

@code {
    private bool IsActive(string path, bool exact = false)
    {
        var current = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        path = path.TrimEnd('/');
        return exact ? current == path : current == path || current.StartsWith(path + "/");
    }
}
