@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService AuthService
@inject IEntryRepository EntryRepo

<PageTitle>Citadel — Home</PageTitle>

<AppHeader Subtitle="Your Daily Gratitude" />

<div class="main-content">
    @if (currentUser is null)
    {
        <div class="loading-spinner">Loading…</div>
    }
    else
    {
        <div class="jar-header-section"></div>

        <div class="home-body">
            <div class="home-greeting">
                <div class="home-greeting-name">Welcome back, @currentUser.FullName!</div>
                <div class="home-greeting-sub">Let's add another moment worth keeping.</div>
            </div>

            <div class="streak-container">
                @if (streak == 0)
                {
                    <img src="/images/streak_none.png" class="streak-none-img" alt="No streak yet" />
                }
                else
                {
                    <div class="streak-ring">🔥</div>
                }
                <div class="streak-label">@streak Streak!</div>
            </div>

            <div class="mood-section">
                <div class="section-label">Mood Distribution</div>
                @if (moodSlices.Count > 0)
                {
                    <div class="mood-chart-row">
                        <div class="mood-pie" style="background: @moodGradient;"></div>
                        <div class="mood-legend">
                            @foreach (var slice in moodSlices)
                            {
                                <div class="mood-legend-item">
                                    <div class="mood-dot" style="background: @slice.Color;"></div>
                                    <span class="mood-legend-text">@slice.Mood</span>
                                    <span class="mood-legend-pct">@slice.Percent%</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="no-moods-hint">Add entries with moods to see your patterns!</div>
                }
            </div>

            @if (latestEntry is not null && !string.IsNullOrWhiteSpace(latestEntry.Mood))
            {
                string moodPrefix, moodSuffix;
                var dateStr = latestEntry.EntryDate.ToString("MMMM d, yyyy");
                if (latestEntry.EntryDate.Date == DateTime.UtcNow.Date) {
                    moodPrefix = "You are feeling"; moodSuffix = " today · " + dateStr;
                } else if (latestEntry.EntryDate.Date == DateTime.UtcNow.Date.AddDays(-1)) {
                    moodPrefix = "Yesterday you were feeling"; moodSuffix = " · " + dateStr;
                } else {
                    moodPrefix = "On " + latestEntry.EntryDate.ToString("MMMM d") + ", you were feeling"; moodSuffix = string.Empty;
                }
                <div class="current-mood-card">
                    <p class="current-mood-text">
                        @moodPrefix <strong class="current-mood-word">@latestEntry.Mood</strong>@moodSuffix
                    </p>
                </div>
            }
        </div>
    }
</div>

<BottomNav />

@code {
    private record MoodSlice(string Mood, int Count, int Percent, string Color);

    private static readonly string[] MoodPalette =
    {
        "#4CAF50", "#2196F3", "#FFC107", "#E91E63", "#9C27B0",
        "#FF5722", "#00BCD4", "#8BC34A", "#FF9800", "#607D8B"
    };

    private GratitudeJar.Models.User? currentUser;
    private int streak;
    private Entry? latestEntry;
    private List<MoodSlice> moodSlices = new();
    private string moodGradient = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser is null) return;

        var all = await EntryRepo.GetAll(currentUser.Id);
        latestEntry = all.FirstOrDefault();

        var jar = new JarApp { Profile = currentUser, Entries = all };
        streak = jar.GetStreak();

        var groups = all
            .GroupBy(e => string.IsNullOrWhiteSpace(e.Mood) ? "Other" : e.Mood)
            .OrderByDescending(g => g.Count())
            .Take(6)
            .ToList();

        var total = groups.Sum(g => g.Count());
        if (total > 0)
        {
            moodSlices = groups
                .Select((g, i) => new MoodSlice(
                    g.Key,
                    g.Count(),
                    (int)Math.Round(g.Count() * 100.0 / total),
                    MoodPalette[i % MoodPalette.Length]
                ))
                .ToList();

            var segments = new List<string>();
            float deg = 0f;
            foreach (var slice in moodSlices)
            {
                var size = slice.Count * 360f / total;
                segments.Add($"{slice.Color} {deg:F1}deg {(deg + size):F1}deg");
                deg += size;
            }
            moodGradient = $"conic-gradient({string.Join(", ", segments)})";
        }
        else
        {
            moodGradient = "conic-gradient(var(--color-surface) 0deg 360deg)";
        }
    }
}
